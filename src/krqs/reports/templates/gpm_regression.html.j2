{% extends "base.html.j2" %}

{% block content %}
<header>
<h1>GPM-Revenue Regression Analysis</h1>
<div class="subtitle">{{ corp_label or "수동 입력 데이터" }}</div>
<div class="meta">
    <span>Confidence: {{ "%.0f%%" | format(confidence * 100) }}</span>
    <span>Outlier removal: {{ "IQR" if remove_outliers else "None" }}</span>
    <span>Observations: {{ result.observations }}{% if result.outliers_removed %} ({{ result.outliers_removed }} removed){% endif %}</span>
</div>
</header>

<h2>회귀 통계량</h2>
<div class="kpi-grid">
    <div class="kpi">
        <div class="label">R²</div>
        <div class="value">{{ "%.4f" | format(result.r_squared) }}</div>
    </div>
    <div class="kpi">
        <div class="label">Slope (매출 1조당)</div>
        <div class="value">{{ "%+.4f" | format(result.slope * 1e12) }}</div>
    </div>
    <div class="kpi">
        <div class="label">Intercept</div>
        <div class="value">{{ "%.4f" | format(result.intercept) }}</div>
    </div>
    <div class="kpi">
        <div class="label">관측치</div>
        <div class="value">{{ result.observations }}</div>
    </div>
</div>

<h2>예측 GPM 밴드</h2>
<div class="kpi-grid" style="grid-template-columns: repeat(3, 1fr);">
    <div class="kpi">
        <div class="label">Low ({{ "%.0f%%" | format(confidence * 100) }} 하한)</div>
        <div class="value">{{ "%.1f%%" | format(result.predicted_gpm_low * 100) }}</div>
    </div>
    <div class="kpi">
        <div class="label">Mid (점추정)</div>
        <div class="value">{{ "%.1f%%" | format(result.predicted_gpm_mid * 100) }}</div>
    </div>
    <div class="kpi">
        <div class="label">High ({{ "%.0f%%" | format(confidence * 100) }} 상한)</div>
        <div class="value">{{ "%.1f%%" | format(result.predicted_gpm_high * 100) }}</div>
    </div>
</div>

<h2>데이터 테이블</h2>
<table class="matrix">
<thead>
<tr>
    <th>연도</th>
    <th>매출(억)</th>
    <th>GPM</th>
    <th>적합값</th>
    <th>잔차</th>
    <th>신뢰하한</th>
    <th>신뢰상한</th>
</tr>
</thead>
<tbody>
{% for row in data_rows %}
<tr>
    <td class="text">{{ row.fiscal_year or "-" }}</td>
    <td>{{ "{:,.0f}".format(row.revenue / 1e8) }}</td>
    <td>{{ "%.2f%%" | format(row.gpm * 100) }}</td>
    <td>{{ "%.2f%%" | format(row.fitted * 100) }}</td>
    <td>{{ "%+.2f%%" | format((row.gpm - row.fitted) * 100) }}</td>
    <td>{{ "%.2f%%" | format(row.lower * 100) }}</td>
    <td>{{ "%.2f%%" | format(row.upper * 100) }}</td>
</tr>
{% endfor %}
</tbody>
</table>

<h2>회귀선 시각화</h2>
<div style="text-align: center; margin: 16px 0;">
<svg viewBox="0 0 600 360" xmlns="http://www.w3.org/2000/svg" style="max-width: 600px; width: 100%; border: 1px solid #e4e7ed; border-radius: 6px; background: #fafbfc;">
  <!-- axes -->
  <line x1="60" y1="300" x2="570" y2="300" stroke="#999" stroke-width="1"/>
  <line x1="60" y1="20" x2="60" y2="300" stroke="#999" stroke-width="1"/>
  <text x="315" y="345" text-anchor="middle" font-size="10" fill="#666">매출액 (억원)</text>
  <text x="15" y="160" text-anchor="middle" font-size="10" fill="#666" transform="rotate(-90, 15, 160)">GPM</text>

  <!-- confidence band -->
  {% if band_points %}
  <polygon points="{{ band_points }}" fill="#4c78a8" fill-opacity="0.15" stroke="none"/>
  {% endif %}

  <!-- regression line -->
  {% if line_points %}
  <polyline points="{{ line_points }}" fill="none" stroke="#e45756" stroke-width="2"/>
  {% endif %}

  <!-- data points -->
  {% for pt in scatter_points %}
  <circle cx="{{ pt.x }}" cy="{{ pt.y }}" r="5" fill="#4c78a8" stroke="white" stroke-width="1">
    <title>{{ pt.label }}</title>
  </circle>
  {% endfor %}

  <!-- Y axis ticks -->
  {% for tick in y_ticks %}
  <line x1="55" y1="{{ tick.y }}" x2="60" y2="{{ tick.y }}" stroke="#999" stroke-width="1"/>
  <text x="52" y="{{ tick.y + 3 }}" text-anchor="end" font-size="9" fill="#666">{{ tick.label }}</text>
  {% endfor %}

  <!-- X axis ticks -->
  {% for tick in x_ticks %}
  <line x1="{{ tick.x }}" y1="300" x2="{{ tick.x }}" y2="305" stroke="#999" stroke-width="1"/>
  <text x="{{ tick.x }}" y="318" text-anchor="middle" font-size="9" fill="#666">{{ tick.label }}</text>
  {% endfor %}
</svg>
</div>

<h2>핵심 관찰</h2>
<ul>
{% for note in observations %}
<li>{{ note }}</li>
{% endfor %}
</ul>
{% endblock %}
